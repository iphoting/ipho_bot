#!/bin/sh

set -e

npm install
export PATH="node_modules/.bin:$PATH"

# Shell adapter logs an error if .hubot_history doesn't exist yet; pre-create it.
touch .hubot_history

# hubot-telegram reads TELEGRAM_TOKEN; bridge from the canonical env var name
if [ -n "$HUBOT_TELEGRAM_TOKEN" ] && [ -z "$TELEGRAM_TOKEN" ]; then
  export TELEGRAM_TOKEN="$HUBOT_TELEGRAM_TOKEN"
fi

# Default to the Telegram adapter unless an adapter is already specified or we
# are running in CI (where no Telegram token is available).
if [ -z "$CI" ] && ! echo " $* " | grep -q -- ' -a '; then
  set -- -a telegram "$@"
fi

exec node_modules/.bin/hubot --name "ipho_bot" "$@"
